{
  "name": "@eml-fn/core",
  "version": "0.0.0",
  "description": "EML (Exp-Minus-Log) function — tree data structures, evaluator, enumerator, code generators",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "eml",
    "exp-minus-log",
    "math",
    "symbolic",
    "expression-tree",
    "code-generation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grzott/eml-fn",
    "directory": "packages/core"
  },
  "sideEffects": false
}
